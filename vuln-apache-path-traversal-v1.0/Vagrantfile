Vagrant.configure("2") do |config|
  # Base image: Ubuntu 22.04 LTS (64-bit)
  config.vm.box = "ubuntu/jammy64"
  config.vm.hostname = "bee-path"

  # The machine will be reachable at this fixed IP on your local network
  config.vm.network "private_network", ip: "192.168.56.10"

  # VirtualBox settings: 1 GB RAM, 1 CPU is enough for this machine
  config.vm.provider "virtualbox" do |vb|
    vb.name   = "btop-bee-path"
    vb.memory = "1024"
    vb.cpus   = 1
    # Disable unnecessary GUI
    vb.gui    = false
  end

  # Provision the VM using Ansible (installed inside the VM itself — no need
  # to have Ansible on your Windows host).
  # provisioning_path sets the working directory Ansible runs from inside the VM.
  # With it set to /vagrant/provision, Ansible automatically finds the roles/
  # subfolder without needing a separate roles_path option.
  config.vm.provision "ansible_local" do |ansible|
    ansible.playbook          = "playbook.yml"
    ansible.provisioning_path = "/vagrant/provision"
    # Suppress deprecation warnings for a cleaner output
    ansible.extra_vars = { ansible_python_interpreter: "/usr/bin/python3" }
  end
end
